SUPABASE_URL=
SUPABASE_SECRET_KEY=
SEC_USER_AGENT=
# Gemini is only used by the manual extraction scripts, never by the API.
GEMINI_API_KEY=
# Optional: override the Gemini model used for extraction.
GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated browser origins allowed to call the API.
# Defaults to the local Next.js dev server when unset.
ALLOWED_ORIGINS=http://localhost:3000
# Shared secret required (as the X-Admin-Token header) by analyst write
# endpoints. Generate a long random private value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_API_TOKEN=
