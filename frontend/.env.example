# Base URL of the FastAPI backend.
# Local development: copy this file to .env.local and keep the default below.
# Production: set this to the deployed API origin (https://...) in the
# hosting provider's environment settings — never commit real values.
# Note: the admin token is NOT configured here. It is entered at runtime in
# the dashboard's Admin Access panel and kept in browser session storage.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
